// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  // pgvector is enabled in the DB; declaring it here lets Prisma keep it
  // in sync via `prisma migrate`.
  extensions = [vector]
}

// === Knowledge base (per-shop RAG) ==================================
// A merchant uploads documents (PDF/MD/TXT). We chunk + embed and store
// chunks alongside their vector. The agent calls search_knowledge_base
// which runs cosine similarity via pgvector.

model KnowledgeDocument {
  id        String   @id @default(uuid())
  shop      String
  // Null = shared across all assistants in the shop. A non-null value
  // scopes this document to that specific assistant only. Retrieval
  // filters to: shared OR (assistantId = active).
  assistantId String?
  filename  String
  mimeType  String
  sizeBytes Int
  // 'ingesting' | 'indexed' | 'failed'
  status    String   @default("ingesting")
  error     String?
  // When this doc came from a crawled web page (sitemap), sourceUrl is
  // the page URL so the agent can cite/link to it. lastmod (from the
  // sitemap entry) lets the crawler skip unchanged pages on re-runs.
  sourceUrl String?
  lastmod   DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  chunks    KnowledgeChunk[]

  @@index([shop])
  @@index([shop, assistantId])
  @@index([shop, createdAt])
  @@index([shop, sourceUrl])
}

model KnowledgeChunk {
  id         String                       @id @default(uuid())
  documentId String
  shop       String
  ordinal    Int
  content    String
  // Cohere embed-v4.0 = 1536 dims (default Matryoshka output). Strong on
  // Nordic languages. Switching models means a fresh migration.
  embedding  Unsupported("vector(1536)")
  tokenCount Int?
  createdAt  DateTime                     @default(now())

  document   KnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([shop])
  @@index([documentId])
}

// One per "support agent persona" a merchant configures. A shop has many
// Assistants (Sales, Returns, General Support, …); exactly one is the
// default (the one customers reach when no specific assistant is targeted).
//
// `config` is a JSON-encoded AssistantConfig (see app/lib/assistants.ts);
// stored as text so both SQLite and Postgres back-ends behave identically.
model Assistant {
  id        String   @id @default(uuid())
  shop      String
  name      String
  isDefault Boolean  @default(false)
  /** Only published assistants are reachable via /api/widget-public-token.
   * Draft assistants stay private so a leaked id can't be chatted with. */
  published Boolean  @default(true)
  /** Bumped to revoke every outstanding widget token for this assistant.
   * Token carries `ep`; chat endpoints reject mismatches. Cheap rotation. */
  tokenEpoch Int     @default(1)
  config    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shop])
  // "At most one default per shop" is enforced at the service layer
  // (assistants.ts) via a transaction that unsets siblings before setting.
  // A partial unique index would be more correct but Prisma doesn't model
  // them — not worth a raw-SQL migration for a single-process pilot.
}

/** Per-shop, per-day LLM token spend. The chat route increments this in
 * the onFinish callback; the next request to start checks against the
 * configured cap and returns 503 if exceeded. Keeps a malicious actor
 * from burning the merchant's whole monthly budget in one afternoon. */
model ShopDailyUsage {
  shop        String
  day         String  // YYYY-MM-DD in UTC
  totalTokens Int     @default(0)
  updatedAt   DateTime @updatedAt

  @@id([shop, day])
  @@index([day])
}

model VerificationCode {
  conversationId String   @id
  email          String
  codeHash       String
  expiresAt      DateTime
  attemptsLeft   Int      @default(5)
  createdAt      DateTime @default(now())

  @@index([expiresAt])
}

model Conversation {
  id            String   @id @default(uuid())
  shop          String
  language      String
  country       String
  verifiedEmail String?
  messages      String   // JSON-encoded array of { role, content }
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([shop])
  @@index([updatedAt])
  // Lookup by email at DSAR-erasure / export time.
  @@index([verifiedEmail])
}

/** GDPR data-subject-access-request audit + one-shot guard. A row is
 * created when a customer hits /api/dsar/start; completedAt is stamped
 * when the magic-link is consumed by /api/dsar/complete. The signed
 * link embeds the row id so re-use after completion is rejected. */
model DsarRequest {
  id          String    @id @default(uuid())
  shop        String
  email       String
  kind        String    // 'export' | 'erase'
  requestedAt DateTime  @default(now())
  completedAt DateTime?

  @@index([shop, email])
  @@index([requestedAt])
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}
