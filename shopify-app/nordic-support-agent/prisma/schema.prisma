// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  // pgvector is enabled in the DB; declaring it here lets Prisma keep it
  // in sync via `prisma migrate`.
  extensions = [vector]
}

// === Knowledge base (per-shop RAG) ==================================
// A merchant uploads documents (PDF/MD/TXT). We chunk + embed and store
// chunks alongside their vector. The agent calls search_knowledge_base
// which runs cosine similarity via pgvector.

model KnowledgeDocument {
  id        String   @id @default(uuid())
  shop      String
  // Null = shared across all assistants in the shop. A non-null value
  // scopes this document to that specific assistant only. Retrieval
  // filters to: shared OR (assistantId = active).
  assistantId String?
  filename  String
  mimeType  String
  sizeBytes Int
  // 'ingesting' | 'indexed' | 'failed'
  status    String   @default("ingesting")
  error     String?
  // When this doc came from a crawled web page (sitemap), sourceUrl is
  // the page URL so the agent can cite/link to it. lastmod (from the
  // sitemap entry) lets the crawler skip unchanged pages on re-runs.
  sourceUrl String?
  lastmod   DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  chunks    KnowledgeChunk[]

  @@index([shop])
  @@index([shop, assistantId])
  @@index([shop, createdAt])
  @@index([shop, sourceUrl])
}

model KnowledgeChunk {
  id         String                       @id @default(uuid())
  documentId String
  shop       String
  ordinal    Int
  content    String
  // Cohere embed-v4.0 = 1536 dims (default Matryoshka output). Strong on
  // Nordic languages. Switching models means a fresh migration.
  embedding  Unsupported("vector(1536)")
  tokenCount Int?
  createdAt  DateTime                     @default(now())

  document   KnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([shop])
  @@index([documentId])
}

// One per "support agent persona" a merchant configures. A shop has many
// Assistants (Sales, Returns, General Support, …); exactly one is the
// default (the one customers reach when no specific assistant is targeted).
//
// `config` is a JSON-encoded AssistantConfig (see app/lib/assistants.ts);
// stored as text so both SQLite and Postgres back-ends behave identically.
model Assistant {
  id        String   @id @default(uuid())
  shop      String
  name      String
  isDefault Boolean  @default(false)
  /** Only published assistants are reachable via /api/widget-public-token.
   * Draft assistants stay private so a leaked id can't be chatted with. */
  published Boolean  @default(true)
  /** Bumped to revoke every outstanding widget token for this assistant.
   * Token carries `ep`; chat endpoints reject mismatches. Cheap rotation. */
  tokenEpoch Int     @default(1)
  config    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shop])
  // "At most one default per shop" is enforced at the service layer
  // (assistants.ts) via a transaction that unsets siblings before setting.
  // A partial unique index would be more correct but Prisma doesn't model
  // them — not worth a raw-SQL migration for a single-process pilot.
}

/** Per-shop, per-day LLM token spend. The chat route increments this in
 * the onFinish callback; the next request to start checks against the
 * configured cap and returns 503 if exceeded. Keeps a malicious actor
 * from burning the merchant's whole monthly budget in one afternoon. */
model ShopDailyUsage {
  shop        String
  day         String  // YYYY-MM-DD in UTC
  totalTokens Int     @default(0)
  updatedAt   DateTime @updatedAt

  @@id([shop, day])
  @@index([day])
}

model VerificationCode {
  conversationId String   @id
  email          String
  codeHash       String
  expiresAt      DateTime
  attemptsLeft   Int      @default(5)
  createdAt      DateTime @default(now())

  @@index([expiresAt])
}

model Conversation {
  id            String   @id @default(uuid())
  shop          String
  language      String
  country       String
  verifiedEmail String?
  messages      String   // JSON-encoded array of { role, content }
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  /** Assistant that handled this conversation. Null = unknown/legacy. */
  assistantId   String?
  /** Bare host of the page the widget loaded on (no path, no query).
   * Captured from the first Origin/Referer the chat endpoint sees. */
  originHost    String?
  /** Sum of LLM tokens spent on this conversation so far. */
  totalTokens   Int      @default(0)
  /** True once create_handoff_ticket has fired for this conversation. */
  handoffTriggered Boolean @default(false)
  /** Derived at finalize/purge time. 'escalated' | 'abandoned' | 'resolved'. */
  outcome       String?
  /** When the conversation was finalized (purge time or explicit close). */
  finalizedAt   DateTime?

  turns         ConversationTurn[]
  toolCalls     ToolCall[]

  @@index([shop])
  @@index([updatedAt])
  // Lookup by email at DSAR-erasure / export time.
  @@index([verifiedEmail])
  @@index([shop, assistantId])
}

/** Per-turn metadata that survives independent of the messages JSON blob.
 * Content stays in Conversation.messages (single source of truth); turns
 * carry only what the insights surface actually queries: timings, token
 * counts, finish reason. Joined by (conversationId, ordinal). */
model ConversationTurn {
  id             String   @id @default(uuid())
  conversationId String
  ordinal        Int
  role           String   // 'user' | 'assistant'
  tokens         Int?
  model          String?
  latencyMs      Int?
  finishReason   String?
  at             DateTime @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, ordinal])
}

/** Audit log of every tool call. Inputs/outputs are JSON strings; the
 * agent's runtime layer is responsible for redacting PII *before* it
 * reaches here when the tier policy requires it. */
model ToolCall {
  id             String   @id @default(uuid())
  conversationId String
  turnOrdinal    Int       // assistant-turn ordinal that produced the call
  name           String
  input          String    // JSON
  output         String    // JSON (may be truncated by writer)
  latencyMs      Int?
  errorMessage   String?
  at             DateTime  @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, turnOrdinal])
  @@index([name])
}

/** Survives the 24h conversation purge. Aggregates only — no PII. The
 * purge cron increments these as it deletes each expiring conversation,
 * so the insights surface can query "last 30 days" without keeping the
 * raw message bodies that long. */
model ConversationDaily {
  shop              String
  day               String  // YYYY-MM-DD UTC of conversation creation
  assistantId       String  // empty string for legacy rows w/o assistant

  conversationCount Int     @default(0)
  resolvedCount     Int     @default(0)
  escalatedCount    Int     @default(0)
  abandonedCount    Int     @default(0)

  totalTokens       Int     @default(0)
  totalTurns        Int     @default(0)

  /** Cumulative tool-call counts as a JSON object: {get_order: 12, ...}. */
  toolCallCounts    String  @default("{}")
  /** Origin-host counts as a JSON object: {"shop.example.com": 47, ...}. */
  originHostCounts  String  @default("{}")

  updatedAt         DateTime @updatedAt

  @@id([shop, day, assistantId])
  @@index([shop])
  @@index([day])
}

/** GDPR data-subject-access-request audit + one-shot guard. A row is
 * created when a customer hits /api/dsar/start; completedAt is stamped
 * when the magic-link is consumed by /api/dsar/complete. The signed
 * link embeds the row id so re-use after completion is rejected. */
model DsarRequest {
  id          String    @id @default(uuid())
  shop        String
  email       String
  kind        String    // 'export' | 'erase'
  requestedAt DateTime  @default(now())
  completedAt DateTime?

  @@index([shop, email])
  @@index([requestedAt])
}

/** Non-Shopify tenant. A workspace owns one or more Assistants, the
 * matching KnowledgeDocuments, Conversations, etc. The `shop` field
 * on those tables holds the workspace.id (a UUID) — Shopify shops use
 * the same column but with a `*.myshopify.com` value. From the rest of
 * the app's perspective, both are opaque tenant strings. */
model Workspace {
  id         String   @id @default(uuid())
  ownerEmail String   @unique
  name       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

/** Short-TTL sign-in code emailed to the owner. One row per email at a
 * time; subsequent issuances overwrite. Lives separately from
 * VerificationCode so customer-email verification and merchant-owner
 * sign-in never share state. */
model WorkspaceSignInCode {
  email        String   @id
  codeHash     String
  expiresAt    DateTime
  attemptsLeft Int      @default(5)
  createdAt    DateTime @default(now())
}

/** Session cookie row. Token is the cookie value; rows hold expiry +
 * workspace pointer. Rotating WIDGET_TOKEN_SECRET does not invalidate
 * these — separate trust domain. */
model WorkspaceSession {
  id          String   @id @default(uuid())
  workspaceId String
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  @@index([workspaceId])
  @@index([expiresAt])
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}
