{
  "name": "@nordic-support/agent",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./run": "./src/agent/run.ts",
    "./tools": "./src/agent/tools.ts",
    "./types": "./src/agent/types.ts",
    "./limits": "./src/agent/limits.ts",
    "./provider": "./src/agent/provider.ts",
    "./env": "./src/env.ts"
  },
  "engines": {
    "node": ">=22.12"
  },
  "scripts": {
    "chat": "tsx src/cli.ts",
    "eval": "tsx src/eval/runner.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "biome check src",
    "format": "biome format --write src"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.78",
    "@ai-sdk/gateway": "^1.0.0",
    "@ai-sdk/google": "^3.0.75",
    "ai": "^6.0.0",
    "dotenv": "^16.4.5",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/node": "^24.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
