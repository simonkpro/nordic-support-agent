# --- Provider selection -----------------------------------------------------
# 'gateway'   = Vercel AI Gateway (default), needs AI_GATEWAY_API_KEY
# 'anthropic' = direct Anthropic API, needs ANTHROPIC_API_KEY
# 'google'    = direct Google Generative AI, needs GOOGLE_GENERATIVE_AI_API_KEY
AI_PROVIDER=anthropic

AI_GATEWAY_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# Model strings. The "provider/model" form (e.g. anthropic/claude-sonnet-4-6)
# works for both gateway and direct providers — the matching prefix is
# stripped before the direct provider sees it.
AGENT_MODEL=anthropic/claude-sonnet-4-6
AGENT_INTENT_MODEL=anthropic/claude-haiku-4-5

# --- Integrations -----------------------------------------------------------
INTEGRATION_MODE=mock

SHOPIFY_SHOP_DOMAIN=
SHOPIFY_ADMIN_TOKEN=

KLARNA_BASE_URL=https://api.playground.klarna.com
KLARNA_USERNAME=
KLARNA_PASSWORD=

POSTNORD_API_KEY=
